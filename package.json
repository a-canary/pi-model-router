{
  "name": "pi-model-router",
  "version": "1.1.0",
  "description": "Pi extension that routes model groups to concrete models. Balances intelligence, cost, and availability.",
  "type": "module",
  "main": "index.ts",
  "pi": {
    "extensions": ["./index.ts"],
    "skills": ["./skills"]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["pi", "pi-extension", "model-router", "llm", "ai"],
  "author": "Aaron Canary",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-canary/pi-model-router.git"
  },
  "files": [
    "index.ts",
    "router-config.json",
    "router-defaults.yaml",
    "model-map.yaml",
    "skills/",
    "PI.md",
    "README.md"
  ],
  "dependencies": {
    "yaml": "^2.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
